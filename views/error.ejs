<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle%></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body, html { height: 100%; }
        .error-container {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
        }
        .error-code {
            font-size: 8rem;
            font-weight: 900;
            letter-spacing: -5px;
            color: #dee2e6;
        }
    </style>
</head>
<body class="bg-light">

<div class="container error-container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="error-code mb-0"><%= status %></h1>
            <h2 class="display-4 fw-bold">Oops! Lost in space?</h2>
            <p class="lead text-muted mb-4">
                <%= message %>
            </p>
            <a href="/" class="btn btn-primary btn-lg px-5 shadow-sm">Take Me Home</a>
        </div>
    </div>
</div>

</body>
</html>